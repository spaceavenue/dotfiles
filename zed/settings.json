// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "edit_predictions": {
    "allow_data_collection": "no"
  },
  "agent_servers": {
    
  },
  "sticky_scroll": {
    "enabled": true
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "indent_guides": {
      "show": "never",
    },
    "git_status_indicator": true,
    "bold_folder_labels": false,
    "dock": "left",
  },
  "selection_highlight": true,
  "scrollbar": {
    "git_diff": false,
    "show": "auto",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "word_diff_enabled": true,
  "code_lens": "on",
  "proxy": "",
  "rounded_selection": true,
  "semantic_tokens": "off",
  "inlay_hints": {
    "show_background": false,
    "enabled": true,
  },
  "agent": {
    "sidebar_side": "right",
    "favorite_models": [],
    "model_parameters": [],
    "show_merge_conflict_indicator": false,
  },
  "window_decorations": "server",
  "title_bar": {
    "show_user_menu": false,
    "show_menus": false,
    "show_onboarding_banner": false,
    "show_sign_in": false,
  },
  "toolbar": {
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": false,
    "agent_review": false,
  },
  "minimap": {
    "show": "never",
  },
  "icon_theme": "Catppuccin Mocha",
  "terminal": {
    "font_family": "Iosevka Term SS06",
    "shell": {
      "program": "/usr/bin/fish"
    },
    "max_scroll_history_lines": 10001,
    "blinking": "on",
    "cursor_shape": "underline",
  },
  "disable_ai": true,
  "text_rendering_mode": "platform_default",
  "ui_font_family": "Iosevka Etoile",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "buffer_font_family": "Iosevka SS06",
  "ui_font_size": 16.0,
  "buffer_font_size": 14.0,
  "theme": "Catppuccin Mocha (pink)",
  "theme_overrides": {
    "Catppuccin Mocha (pink)": {
      "editor.background": "#18000f",
      "editor.gutter.background": "#18000f",
      "terminal.background": "#000000",
      "terminal.ansi.background": "#000000",
      "status_bar.background": "#18000f",
      "scrollbar.track.background": "#18000f",
      "border": "#00000000",
      "border.focused": "#00000000",
      "border.selected": "#00000000",
      "border.transparent": "#00000000",
      "border.disabled": "#00000000",
      "toolbar.background": "#18000f",
      "title_bar.background": "#18000f",
      "tab_bar.background": "#18000f",
      "elevated_surface.background": "#18000f",
      "surface.background": "#18000f",
      "panel.background": "#18000f",
      "panel.overlay_background": "#18000f",
      "editor.subheader.background": "#18000f",
      "hidden.background": "#18000f",
      "hint.background": "#18000f",
      "predictive.background": "#18000f",
      "players": [
        {
          "cursor": "#ffd1db",
          "selection": "#ffd1db44",
          "background": "#f38ba8",
        },
      ],
      "syntax": {
        "comment": {
          "font_style": "italic",
        },
        "comment.doc": {
          "font_style": "italic",
        },
      },
    },
  },
}
