{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "spacing": 5,
    "margin": "5px 5px 0px 5px",
    // "height": 40,
    "modules-left": [ 
        "niri/workspaces",
        //"group/group-taskbar",
        //"wlr/taskbar", 
        "group/group-cpu",  
        "custom/memory", 
        "disk"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/weather",
        "wireplumber", 
        "battery", 
        "network", 
        "tray"
    ],

    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "",
            "terminal": "",
            "browser": "󰈹",
            "chat": ""
        },
        "hide-empty": true
    },

