{
    "layer": "top",
    "position": "top",
    "exclusive": true,
    "spacing": 5,
    "margin": "5px 5px 0px 5px",
    "modules-left": [
        "niri/workspaces",
        "group/group-cpu",  
        "custom/memory", 
        "disk"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/weather",
        "wireplumber", 
        "battery",
        "inhibitor",
        "network"
        // "tray"
    ],

    "niri/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "default": "пЂ„",
            "terminal": "п’‰",
            "browser": "у°€№",
            "chat": "п‡ї"
        },
        "hide-empty": true
    },

    "group/group-cpu": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "children-class": "cpu-related",
            "click-to-reveal": true
        },
        "modules": [
            "cpu",
            "temperature"
        ]
    },

    "cpu": {
        "interval": 2,
        "format": "<span foreground='#ffd1db'>п‹›</span> {usage}%",
        "tooltip": false
    },

    "temperature": {
        "interval": 2,
        "thermal-zone": 0,
        "hwmon-path": "/sys/devices/platform/thinkpad_hwmon/hwmon/hwmon7/temp1_input",
        "format": "<span foreground='#ffd1db'>у±ѓѓ</span> {temperatureC}В°C",
        "tooltip": false
    },
    
    "custom/memory": {
        "exec": "~/.config/waybar/scripts/memory.sh",
        "interval": 5,
        "format": "<span foreground='#ffd1db'>ої…</span> {}",
        "tooltip": false
    },

    "disk": {
        "interval": 10,
        "path": "/",
        "format": "<span foreground='#ffd1db'>п€і</span> {free}",
        "tooltip": false
    },

    "clock": {
        "interval": 1,
        "format": "<span foreground='#ffd1db'>у°…ђ</span> {:%a - %H:%M}",
        "format-alt": "<span foreground='#ffd1db'>у°ё—</span> {:%a, %d %b %y   <span foreground='#ffd1db'>у°…ђ </span> %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "weeks-pos"     : "left",
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#89b4fa'><b>{}</b></span>",
                              "days":       "<span color='#ff7aba'><b>{}</b></span>",
                              "weeks":      "<span color='#a6e3a1'><b>W{}</b></span>",
                              "weekdays":   "<span color='#f38ba8'><b>{}</b></span>",
                              "today":      "<span color='#ffd1db'><b><u>{}</u></b></span>"
                              }
                    },
        "tooltip": true
    },
    
    "custom/weather": {
        "interval": 3600,
        "exec": "${HOME}/.config/waybar/scripts/weather.sh Delhi+India",
        "return-type": "json",
        "format": "<span foreground='#ffd1db'>у°…џ</span> {}",
        "tooltip": false
    },

    "wireplumber": {
        "format": "<span foreground='#ffd1db'>{icon}</span> {volume}%",
        "format-muted": "<span foreground='#ffd1db'>у°ќџ</span> Muted",
        "format-icons": ["у°•ї", "у°–Ђ", "у°•ѕ"],
        "on-click-right": "pavucontrol",
        "tooltip":  false
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "<span foreground='#ffd1db'>{icon}</span> {capacity}%",
        "format-charging": "<span foreground='#ffd1db'>{icon}</span> {capacity}%",
        "format-plugged": "<span foreground='#ffd1db'>п‰Ђ</span> {capacity}%",
        "format-full": "<span foreground='#ffd1db'>п‰Ђ</span> {capacity}%",
        "tooltip-format": "{timeTo}",
        "format-icons": {
            "charging": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
            "default": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
        },
        "format-time": "{H}:{M}",
        "interval": 30
    },
    "inhibitor": {
        "what": "idle",
        "format": "{icon}",
        "format-icons": {
            "activated": "у°’і",
            "deactivated": "у°’І"
        },
        "tooltip": false
    },

    "network": {
        "interval": 5,
        "interface": "wlan0",
        "format-wifi": "<span foreground='#ffd1db'>{icon}</span> {essid}",
        "format-icons": {
            "wifi": ["у°¤Ї", "у°¤џ", "у°¤ў", "у°¤Ґ", "у°¤Ё"]
        },
        "format-ethernet": "<span foreground='#ffd1db'>у°€Ђ</span> Connected",
        "format-disconnected": "<span foreground='#ffd1db'>у°І›</span> Offline",
        "tooltip": false
    }

    // "tray": {
    //     "icon-size": 18,
    //     "spacing": 5,
    //     "show-passive-items": true
    // }
}
